{
    NUM_MASTERS = 1;
    NUM_NODES = 3;
    NUM_OFFSHORE_DATA_GATEWAYS = 1;
    NUM_SCHEDULERS = 0;
    NUM_CONTROLLER_AGENTS = 0;

    DELTA_RPC_PROXY_CONFIG = {
        cluster_connection = {
            medium_directory_synchronizer = {
                sync_period = 10;
                use_cache = %false;
            };
        };
    };
    DELTA_OFFSHORE_DATA_GATEWAY_CONFIG = {
        cluster_connection = {
            medium_directory_synchronizer = {
                sync_period = 10;
                use_cache = %false;
            };
        };
    };
    DELTA_NODE_CONFIG = {
        cluster_connection = {
            medium_directory_synchronizer = {
                sync_period = 10;
                use_cache = %false;
            };
        };
    };

    DELTA_MASTER_CONFIG = {
        object_service = {
            timeout_backoff_lead_time = 100;
        };
    };
    DELTA_DYNAMIC_MASTER_CONFIG = {
        chunk_manager = {
            allow_offshore_media = %true;
        };
    };
    DELTA_DRIVER_CONFIG = {
        medium_directory_synchronizer = {
            sync_period = 10;
            use_cache = %false;
        };
        transaction_manager = {
            ping_batcher = {
                enable = %true;
                batch_size = 2;
                batch_period = 1000;
            };
        };
    };
    DRIVER_BACKEND = native;
    NUM_RPC_PROXIES = 1;
}
