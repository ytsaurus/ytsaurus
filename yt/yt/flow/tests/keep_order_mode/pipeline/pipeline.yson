{
    "cluster_url" = "<to_be_overridden>";
    "path" = "//<to_be_overridden>";
    "spec" = {
        "computations" = {
            "Reader" = {
                "computation_class_name" = "NExample::TReader";
                "input_stream_ids" = [];
                "output_stream_ids" = ["event_0"];
                "source_streams" = {
                    "queue" = {
                        "source_class_name" = "NYT::NFlow::TQueueSource";
                        "parameters" = {
                            "queue_path" = "//<to_be_overridden>";
                            "consumer_path" = "//<to_be_overridden>";
                        };
                    };
                };
                "watermark_strategy" = {
                    "event_timestamp_assigner" = {
                        "column" = "event_time";
                    };
                };
            };
            "Shuffle_1" = {
                "computation_class_name" = "NExample::TRacyPassthroughComputation";
                "group_by_schema" = [
                    {"name" = "hash"; "expression" = "farm_hash(reduce_id) * 1009"; "type" = "uint64"; required = %true;};
                    {"name" = "reduce_id"; "type" = "uint64";};
                ];
                "input_stream_ids" = ["event_0"];
                "output_stream_ids" = ["event_1"];
            };
            "Shuffle_2" = {
                "computation_class_name" = "NExample::TRacyPassthroughComputation";
                "group_by_schema" = [
                    {"name" = "hash"; "expression" = "farm_hash(reduce_id) * 13"; "type" = "uint64"; required = %true;};
                    {"name" = "reduce_id"; "type" = "uint64";};
                ];
                "input_stream_ids" = ["event_1"];
                "output_stream_ids" = ["event_2"];
            };
            "QueueReducer" = {
                "computation_class_name" = "NExample::TQueueReducer";
                "group_by_schema" = [
                    {"name" = "hash"; "expression" = "farm_hash(reduce_id)"; "type" = "uint64"; required = %true;};
                    {"name" = "reduce_id"; "type" = "uint64";};
                ];
                "input_stream_ids" = ["event_2"];
                "output_stream_ids" = ["sink_event"];
                "sinks" = {
                    "queue" = {
                        "sink_class_name" = "NYT::NFlow::TSyncQueueSink";
                        "input_stream_ids" = ["sink_event";];
                        "parameters" = {
                            "queue_path" = "//<to_be_overridden>";
                        };
                    };
                };
            };
        };
        "streams" = {
            "event_0" = {
                "schema" = [
                    {"name" = "reduce_id"; "type" = "uint64";};
                    {"name" = "event_id"; "type" = "int64";};
                    {"name" = "event_time"; "type" = "uint64";};
                ];
            };
            "event_1" = {
                "schema" = [
                    {"name" = "reduce_id"; "type" = "uint64";};
                    {"name" = "event_id"; "type" = "int64";};
                    {"name" = "event_time"; "type" = "uint64";};
                ];
            };
            "event_2" = {
                "schema" = [
                    {"name" = "reduce_id"; "type" = "uint64";};
                    {"name" = "event_id"; "type" = "int64";};
                    {"name" = "event_time"; "type" = "uint64";};
                ];
            };
            "sink_event" = {
                "schema" = [
                    {"name" = "reduce_id"; "type" = "uint64";};
                    {"name" = "event_id"; "type" = "int64";};
                ];
            };
        };
    };
    "dynamic_spec" = {
        "computations" = {
            "Reader" = {
                "batch_duration" = 100;
                "max_rows_per_batch" = 10;
            };
            "Shuffle_1" = {
                "parameters" = {"desired_partition_count" = 8;};
            };
            "Shuffle_2" = {
                "parameters" = {"desired_partition_count" = 8;};
            };
            "QueueReducer" = {
                "parameters" = {"desired_partition_count" = 8;};
            };
        };
        "job_tracker" = {
